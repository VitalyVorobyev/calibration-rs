node_modules
src-tauri/target
src-tauri/gen
tsconfig.tsbuildinfo
# `dist/` is regenerated by `bun run build`. We commit a placeholder
# `index.html` so `cargo check` for the Tauri backend succeeds before
# `bun install` has ever run; the placeholder is the only thing that
# survives a checkout.
dist/*
!dist/.gitkeep
!dist/index.html
