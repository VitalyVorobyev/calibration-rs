node_modules
src-tauri/target
src-tauri/gen
# `dist/` is regenerated by `npm run build`. We commit a placeholder
# `index.html` so `cargo check` for the Tauri backend succeeds before
# `npm install` has ever run; the placeholder is the only thing that
# survives a checkout.
dist/*
!dist/.gitkeep
!dist/index.html
